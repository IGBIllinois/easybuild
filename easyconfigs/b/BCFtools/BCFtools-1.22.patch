+static inline void reverse_complement(char *str) {
+    int i, len = strlen(str);
+    for (i = 0; i < len / 2; i++) {
+        char tmp = str[i];
+        str[i] = rev_nt(str[len - i - 1]);
+        str[len - i - 1] = rev_nt(tmp);
+    }
+    if (len % 2 == 1) str[len / 2] = rev_nt(str[len / 2]);
+}
