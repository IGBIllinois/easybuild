+    }
+
+    hdr = bcf_sr_get_header(sr, 0);
+    bcf_hdr_t *out_hdr = bcf_hdr_init("w");
+    int *id = (int *)malloc(sizeof(int) * SIZE * n_files);
+    int output[SIZE] = {0};
