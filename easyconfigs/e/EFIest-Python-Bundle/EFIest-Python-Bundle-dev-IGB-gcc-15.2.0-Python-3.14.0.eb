easyblock = 'PythonPackage'

name = 'EFIest-Python-Bundle'
version = 'dev'
versionsuffix = '-Python-%(pyver)s'
local_commit = '8ba200d'

homepage = 'https://github.com/EnzymeFunctionInitiative/EST'
description = '''EFI-EST is a flexible pipeline which builds Sequence Similarity Networks of proteins for the purpose of elucidating the function of enzymes. It is available through a web tool at https://efi.igb.illinois.edu/efi-est/ and on KBase. This respository contains the analysis code that these services use. '''

toolchain = {'name': 'IGB-gcc', 'version': '15.2.0'}

sources = [{'filename': 'efiest-%(version)s.tar.xz',
        'git_config': {
                'url': 'https://github.com/EnzymeFunctionInitiative',
                'repo_name': 'EST',
                'commit': local_commit,
                'recursive': True,
        },
}]

builddependencies = [
        ('pkgconf','2.4.3'),
        ('CMake','4.2.0'),
        ('Meson','1.8.2'),
        ('meson-python','0.18.0'),
        ('Ninja','1.13.0'),
        ('Rust','1.92.0'),
]

dependencies = [
        ('Python', '3.14.0'),
	('libjpeg-turbo','3.1.3'),
]

start_dir = "lib/pyEFI"

use_pip = True
sanity_pip_check = True
unpack_sources = True
exts_filter = ('python -c "import %(ext_name)s"', "")

options = { 'modulename': 'pyEFI' }

exts_default_options = {
	'source_urls': [PYPI_SOURCE],
	'sanity_pip_check': True,
	'unpack_sources': False
}

check_readelf_rpath = False

exts_defaultclass = "PythonPackage"
exts_list = [
	('Cython', '3.2.3', {
                'source_tmpl': 'cython-%(version)s.tar.gz'
        }),
	('numpy', '2.3.5', {
                'runtest': False,
                'easyblock': 'PythonPackage'
        }),
	('pathspec','0.12.1'),
	('pluggy','1.6.0'),
	('trove_classifiers','2025.12.1.14', {
                'source_tmpl': SOURCE_PY3_WHL,
        }),
	('hatchling','1.28.0'),
	('hatch-vcs','0.5.0', {
                'source_tmpl': 'hatch_vcs-%(version)s.tar.gz'
        }),
	('scipy', '1.16.3', {
                'source_tmpl': 'scipy-%(version)s-cp314-cp314-manylinux2014_x86_64.manylinux_2_17_x86_64.whl',
                'easyblock': 'PythonPackage'
        }),
#	('scikit-learn','1.8.0', {
#                'source_tmpl': 'scikit_learn-%(version)s.tar.gz',
#                'modulename': 'sklearn',
#        }),
        ('scikit-build-core','0.11.6', {
